# Copy this file to a `.env` at the repo root and fill in your real keys.
#   cp 01_secure_setup/.env.example .env
#
# Never commit `.env` itself. The example file lives here so the repo
# documents which variables are expected without leaking any secrets.

# Google AI Studio: https://aistudio.google.com/apikey  (free tier available)
GEMINI_API_KEY=your_gemini_key_here

# Hugging Face: https://huggingface.co/settings/tokens  (read-access is fine for most demos)
HF_TOKEN=your_hf_token_here

# OpenAI: https://platform.openai.com/api-keys  (requires billing setup)
OPENAI_API_KEY=your_openai_key_here
